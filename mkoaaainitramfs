#!/bin/bash
# mkoaaainitramfs - builds a fully static initramfs for oaaa boot
# compiles busybox, zstd, zlib, kexec-tools from source - nothing from host
set -eu

NPROC=$(nproc)
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
BUILD="$SCRIPT_DIR/initramfs-build"
OUT="$SCRIPT_DIR/initramfs-root"
SYSROOT="$BUILD/sysroot"

BUSYBOX_VER="1.37.0"
ZLIB_VER="1.3.1"
ZSTD_VER="1.5.6"
KEXEC_VER="2.0.32"

if [[ $EUID -ne 0 ]]; then echo "must be run as root"; exit 1; fi

mkdir -p "$BUILD/src" "$SYSROOT"/{lib,include}

cd "$BUILD/src"

# ---- busybox (static) ----
if [ ! -f "$BUILD/busybox" ]; then
  echo "==> building busybox $BUSYBOX_VER..."
  [ -d "busybox-$BUSYBOX_VER" ] || {
    [ -f "busybox-$BUSYBOX_VER.tar.bz2" ] || wget -q --show-progress \
      "https://busybox.net/downloads/busybox-$BUSYBOX_VER.tar.bz2"
    tar xf "busybox-$BUSYBOX_VER.tar.bz2"
  }
  cd "busybox-$BUSYBOX_VER"
  make defconfig
  # enable static, disable stuff we don't need
  sed -i 's/# CONFIG_STATIC is not set/CONFIG_STATIC=y/' .config
  sed -i 's/CONFIG_TC=y/# CONFIG_TC is not set/' .config
  sed -i 's/CONFIG_FEATURE_IP_RULE=y/# CONFIG_FEATURE_IP_RULE is not set/' .config
  make -j"$NPROC" 2>/dev/null
  cp busybox "$BUILD/busybox"
  cd "$BUILD/src"
  echo "==> busybox done"
fi

# ---- zlib (static, for kexec) ----
if [ ! -f "$SYSROOT/lib/libz.a" ]; then
  echo "==> building zlib $ZLIB_VER..."
  [ -d "zlib-$ZLIB_VER" ] || {
    [ -f "zlib-$ZLIB_VER.tar.gz" ] || wget -q --show-progress \
      "https://github.com/madler/zlib/releases/download/v$ZLIB_VER/zlib-$ZLIB_VER.tar.gz"
    tar xf "zlib-$ZLIB_VER.tar.gz"
  }
  cd "zlib-$ZLIB_VER"
  ./configure --prefix="$SYSROOT" --static
  make -j"$NPROC" install
  cd "$BUILD/src"
  echo "==> zlib done"
fi

# ---- zstd (static binary + static lib for kexec) ----
if [ ! -f "$BUILD/zstd" ]; then
  echo "==> building zstd $ZSTD_VER..."
  [ -d "zstd-$ZSTD_VER" ] || {
    [ -f "zstd-$ZSTD_VER.tar.gz" ] || wget -q --show-progress \
      "https://github.com/facebook/zstd/releases/download/v$ZSTD_VER/zstd-$ZSTD_VER.tar.gz"
    tar xf "zstd-$ZSTD_VER.tar.gz"
  }
  cd "zstd-$ZSTD_VER"
  # build static library
  make -C lib -j"$NPROC" ZSTD_LIB_MULTITHREADING=0
  cp lib/libzstd.a "$SYSROOT/lib/"
  cp lib/zstd.h "$SYSROOT/include/"
  # build static binary
  make -j"$NPROC" LDFLAGS="-static" ZSTD_LIB_MULTITHREADING=0 zstd-release
  cp zstd "$BUILD/zstd"
  cd "$BUILD/src"
  echo "==> zstd done"
fi

# ---- kexec-tools (static, with zlib+zstd) ----
if [ ! -f "$BUILD/kexec" ]; then
  echo "==> building kexec-tools $KEXEC_VER..."
  [ -d "kexec-tools-$KEXEC_VER" ] || {
    [ -f "kexec-tools-$KEXEC_VER.tar.gz" ] || wget -q --show-progress \
      "https://mirrors.edge.kernel.org/pub/linux/utils/kernel/kexec/kexec-tools-$KEXEC_VER.tar.gz"
    tar xf "kexec-tools-$KEXEC_VER.tar.gz"
  }
  cd "kexec-tools-$KEXEC_VER"
  ./configure \
    CFLAGS="-I$SYSROOT/include" \
    LDFLAGS="-L$SYSROOT/lib -static" \
    --without-lzma
  make -j"$NPROC"
  cp build/sbin/kexec "$BUILD/kexec"
  cd "$BUILD/src"
  echo "==> kexec done"
fi

# ---- assemble initramfs ----
echo "==> assembling initramfs..."
rm -rf "$OUT"
mkdir -p "$OUT"/{bin,sbin,dev,proc,sys,data,erofs,overlay,mnt,tmp,lib/modules}

cp "$BUILD/busybox" "$OUT/bin/busybox"
cp "$BUILD/kexec"   "$OUT/bin/kexec"
cp "$BUILD/zstd"    "$OUT/bin/zstd"

# install all busybox applets as hard links (avoids absolute symlink path issues)
"$OUT/bin/busybox" --install "$OUT/bin"
# manually hard-link anything busybox --install misses
for cmd in mkdir rm rmdir cp mv ln chmod chown; do
  [ -e "$OUT/bin/$cmd" ] || cp "$OUT/bin/busybox" "$OUT/bin/$cmd"
done

# init script
cp "$SCRIPT_DIR/initramfs-init" "$OUT/init"
chmod +x "$OUT/init"

# build the image
(cd "$OUT" && find . | cpio -H newc -o | gzip > "$SCRIPT_DIR/initramfs-oaaa.img")
echo "==> initramfs done: $SCRIPT_DIR/initramfs-oaaa.img ($(du -sh "$SCRIPT_DIR/initramfs-oaaa.img" | cut -f1))"
