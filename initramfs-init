#!/bin/sh
# oaaa initramfs init - two-stage boot via kexec
# stage 1: builds dynamic initramfs with EROFS modules, kexecs EROFS kernel
# stage 2: depmod + modprobe all modules from initramfs, mounts overlay, switch_roots

mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev
exec > /dev/console 2>&1
exec < /dev/console

if grep -q "oaaa.stage=2" /proc/cmdline 2>/dev/null; then
  # ---- STAGE 2 ----
  echo "[oaaa] stage 2: loading modules..."
  echo 1 > /proc/sys/kernel/printk

  # modules are embedded in this initramfs at /lib/modules/
  # depmod builds the dependency tree, then modprobe resolves and loads
  KVER=$(uname -r)
  echo "[oaaa] kernel: $KVER"
  depmod "$KVER" 2>/dev/null || depmod 2>/dev/null
  echo "[oaaa] depmod done"

  for mod in netfs erofs loop overlay; do
    modprobe "$mod" 2>/dev/null && echo "[oaaa] loaded $mod" || echo "[oaaa] $mod failed/built-in"
  done

  echo 7 > /proc/sys/kernel/printk
  echo "[oaaa] stage 2: setting up overlay..."

  # storage modules now loaded - find data partition
  DATA_DEV=$(blkid 2>/dev/null | grep 'LABEL="OAAA_DATA"' | head -1 | cut -d: -f1)
  echo "[oaaa] data dev: $DATA_DEV"
  if [ -n "$DATA_DEV" ]; then
    mkdir -p /data
    mount -t ext4 "$DATA_DEV" /data 2>/dev/null
  else
    echo "[oaaa] FATAL: OAAA_DATA not found"
    exec sh
  fi

  for i in 0 1 2 3 4 5 6 7; do
    [ -e "/dev/loop$i" ] || mknod "/dev/loop$i" b 7 "$i" 2>/dev/null
  done

  NEWEST=$(ls -t /data/images/*.erofs 2>/dev/null | head -1)
  [ -z "$NEWEST" ] && { echo "[oaaa] FATAL: no erofs images"; exec sh; }
  echo "[oaaa] image: $(basename "$NEWEST")"

  echo "[oaaa] fs: $(grep erofs /proc/filesystems 2>/dev/null || echo 'erofs NOT in /proc/filesystems')"
  echo "[oaaa] loop: $(grep loop /proc/modules 2>/dev/null | head -1 || echo 'loop NOT in /proc/modules')"

  mkdir -p /erofs
  mount -t erofs -o ro "$NEWEST" /erofs || { echo "[oaaa] FATAL: cannot mount erofs"; exec sh; }

  mkdir -p /data/overlay/upper /data/overlay/work /overlay

  mount -t overlay overlay \
    -o lowerdir=/erofs,upperdir=/data/overlay/upper,workdir=/data/overlay/work,index=off \
    /overlay || { echo "[oaaa] FATAL: overlayfs failed"; exec sh; }
  echo "[oaaa] overlay ready, switching root..."

  if grep -q "oaaa.shell=2" /proc/cmdline 2>/dev/null; then
    echo "[oaaa] dropping to stage 2 shell (oaaa.shell=2)"
    echo "[oaaa] modules loaded, erofs at /erofs, overlay at /overlay, data at /data"
    exec sh
  fi

  mkdir -p /overlay/oaaa
  mount --bind /data /overlay/oaaa

  mkdir -p /overlay/proc /overlay/sys /overlay/dev
  mount --move /proc /overlay/proc
  mount --move /sys /overlay/sys
  mount --move /dev /overlay/dev

  exec switch_root /overlay /sbin/init

else
  # ---- STAGE 1 ----
  echo "[oaaa] stage 1: starting..."
  sleep 1

  DATA_DEV=$(blkid 2>/dev/null | grep 'LABEL="OAAA_DATA"' | head -1 | cut -d: -f1)
  [ -z "$DATA_DEV" ] && { echo "[oaaa] FATAL: no OAAA_DATA"; exec sh; }
  echo "[oaaa] data: $DATA_DEV"

  mkdir -p /data
  mount -t ext4 "$DATA_DEV" /data || { echo "[oaaa] FATAL: cannot mount data"; exec sh; }

  if grep -q "oaaa.shell=1" /proc/cmdline 2>/dev/null; then
    echo "[oaaa] dropping to stage 1 shell (oaaa.shell=1)"
    exec sh
  fi

  NEWEST=$(ls -t /data/images/*.erofs 2>/dev/null | head -1)
  [ -z "$NEWEST" ] && { echo "[oaaa] FATAL: no erofs images"; exec sh; }

  mkdir -p /erofs
  mount -t erofs -o ro "$NEWEST" /erofs || { echo "[oaaa] FATAL: cannot mount erofs"; exec sh; }

  KVER=$(ls /erofs/lib/modules/ 2>/dev/null | head -1)
  echo "[oaaa] EROFS kernel: $KVER"

  # build dynamic initramfs: extract EROFS modules into a cpio, append to base initramfs
  echo "[oaaa] building dynamic stage2 initramfs with modules..."
  MODSTAGE="/data/tmp-modbuild/lib/modules/$KVER"
  rm -rf /data/tmp-modbuild
  mkdir -p "$MODSTAGE"

  # decompress .ko.zst and copy plain .ko into the staging tree
  find "/erofs/lib/modules/$KVER" -name "*.ko.zst" 2>/dev/null | while read f; do
    name=$(basename "$f" .zst)
    zstd -d "$f" -o "$MODSTAGE/$name" 2>/dev/null
  done
  find "/erofs/lib/modules/$KVER" -name "*.ko" 2>/dev/null | while read f; do
    cp "$f" "$MODSTAGE/"
  done
  # copy module metadata so depmod works correctly in stage 2
  for meta in modules.order modules.builtin modules.builtin.modinfo; do
    [ -f "/erofs/lib/modules/$KVER/$meta" ] && cp "/erofs/lib/modules/$KVER/$meta" "$MODSTAGE/"
  done
  echo "[oaaa] modules staged: $(ls $MODSTAGE/*.ko 2>/dev/null | wc -l) files"

  # build a cpio from the staging tree and append to base initramfs
  # linux accepts concatenated cpio archives as a single initramfs
  MODCPIO="/data/tmp-modules.cpio"
  (cd /data/tmp-modbuild && find . | cpio -o -H newc 2>/dev/null | zstd -1 -T0) > "$MODCPIO"
  STAGE2_IMG="/data/stage2-dynamic.img"
  cat /data/initramfs-oaaa.img "$MODCPIO" > "$STAGE2_IMG"
  echo "[oaaa] dynamic initramfs ready: $(ls -lh $STAGE2_IMG | awk '{print $5}')"

  echo "[oaaa] kexecing to EROFS kernel..."
  kexec -l /erofs/boot/vmlinuz-linux \
    --initrd="$STAGE2_IMG" \
    --append="console=tty0 console=ttyS0,115200 oaaa.stage=2" || { echo "[oaaa] FATAL: kexec failed"; exec sh; }

  umount /erofs /data 2>/dev/null
  kexec -e
  echo "[oaaa] FATAL: kexec -e returned"
  exec sh
fi
